# =============================================================================
#  BTC Scalping Signal Bot — Environment Variables
# =============================================================================
#  Copy this to .env and fill in your credentials.
#  ONLY Delta Exchange requires API keys. All other sources are free public APIs.

# Delta Exchange India — API Key & Secret
# Generate at: https://www.delta.exchange/app/account/api-keys
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here

# Telegram — (placeholder for future integration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
